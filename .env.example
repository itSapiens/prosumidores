# ============================================================
# Variables de entorno de la aplicación
# ============================================================
# Copia este archivo a .env.local y rellena los valores.
# .env.local está ignorado por git (ver .gitignore).
#
# En producción (Cloud Run / Cloud Build) estas variables se
# inyectan en tiempo de build a través de --build-arg.
# ============================================================

# URL del proyecto Supabase (unificado: auth + datos)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Anon / publishable key del proyecto (pública, va al bundle JS)
# NO confundir con service_role, que nunca debe ir al cliente.
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
